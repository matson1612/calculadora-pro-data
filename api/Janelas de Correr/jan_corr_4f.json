        "fecho_1570": ["1570"],
        "fecho_3532jm": ["3532jmvv"]
    },
    "componentes_composicao": ["escovinha_5x7", "acess_de_4f"],
    "variaveis_calculo": [
        { "nome": "H_MOV", "formula": "{H} - 25" },
        { "nome": "H_FIX", "formula": "{H} - 65" },
        { "nome": "HFEC", "formula": "ROUND(({H} / 2) - 50)" },
        { "nome": "BASE_L", "formula": "({L} / 4) + 50" },
        { "nome": "L_MOV", "formula": "(FLOOR(({BASE_L} + 21) / 50) * 50 > {BASE_L}) ? (FLOOR({BASE_L} / 5) * 5) : (FLOOR({BASE_L} / 50) * 50)" },
        { "nome": "TEMP_FIX", "formula": "({L} / 4) + (({L} / 4) + 50 - {L_MOV})" },
        { "nome": "L_FIX", "formula": "FLOOR({TEMP_FIX} > {L_MOV} ? {L_MOV} : {TEMP_FIX})" }
    ],
    "vidros": [
        { "tipo": "Móvel", "isMovel": true, "w": "{L_MOV}", "h": "{H_MOV}", "qtd": 2 },
        { "tipo": "Fixa", "isMovel": false, "w": "{L_FIX}", "h": "{H_FIX}", "qtd": 2 }
    ],
    "perfis": [
        { "cod": "trilho_8mm", "tam": "{L}", "qtd": 1, "meta": "Trilho Superior" },
        { "cod": "capa_8mm", "tam": "{L}", "qtd": 1, "meta": "Capa do Trilho" },
