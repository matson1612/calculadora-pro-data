                { "nome": "L_MOV", "formula": "FLOOR(({BASE_L} + 24) / 50) * 50" },
                { "nome": "TEMP_FIX", "formula": "({L} / 2) + (({L} / 2) + 50 - {L_MOV})" },
                { "nome": "L_FIX", "formula": "FLOOR({TEMP_FIX} > {L_MOV} ? {L_MOV} : {TEMP_FIX})" },
                { "nome": "H_MOV_EMB", "formula": "{H} - 0" },
                { "nome": "H_FIX_EMB", "formula": "{H} - 60" },
                { "nome": "H_MOV_EXP", "formula": "{H} - 25" },
                { "nome": "H_FIX_EXP", "formula": "{H} - 65" },
                { "nome": "HFEC", "formula": "1050" },
                { "nome": "HFURO", "formula": "1050 - ({ENTRE_FUROS} / 2)" }
            ],
            "vidros": [
                { "tipo": "Móvel", "isMovel": true, "w": "{L_MOV}", "h": "{H_MOV_EMB}", "qtd": 1, "condicao": "\"{TRILHO}\" == \"EMBUTIDO\"" },
